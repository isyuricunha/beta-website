    "astro": "6.4.6",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "gray-matter": "4.0.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
