---
import StaticSectionPage from "@/components/pages/StaticSectionPage.astro";
import {
  nonDefaultLocales,
  type Locale,
} from "@/i18n/config";
import { sections, type Section } from "@/i18n/types";

export function getStaticPaths() {
  return nonDefaultLocales.flatMap((locale) =>
    sections.map((section) => ({
      params: { locale, section },
      props: { locale, section },
    })),
  );
}

type Props = {
  locale: Locale;
  section: Section;
};

const { locale, section } = Astro.props;
---

<StaticSectionPage locale={locale} section={section} />
