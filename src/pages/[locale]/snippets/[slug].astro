---
import type { CollectionEntry } from "astro:content";

import SnippetPage from "@/components/pages/SnippetPage.astro";
import type { Locale } from "@/i18n/config";
import {
  getAvailableLocales,
  getPublishableEntries,
} from "@/lib/content";
import { parseContentId } from "@/lib/content-utils";

export async function getStaticPaths() {
  const entries = await getPublishableEntries("snippets");

  return Promise.all(
    entries
      .filter((entry) => parseContentId(entry.id).locale !== "en")
      .map(async (entry) => {
        const { locale, slug } = parseContentId(entry.id);
        return {
          params: { locale, slug },
          props: {
            entry,
            availableLocales: await getAvailableLocales("snippets", slug),
          },
        };
      }),
  );
}

type Props = {
  entry: CollectionEntry<"snippets">;
  availableLocales: Locale[];
};

const { entry, availableLocales } = Astro.props;
---

<SnippetPage entry={entry} availableLocales={availableLocales} />
