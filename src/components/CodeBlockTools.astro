<script>
  import { getCodeLanguageLabel } from "@/lib/code-blocks";

  const codeBlockScopeSelector = "[data-code-block-scope]";

  function enhanceCodeBlocks(): void {
    document
      .querySelectorAll<HTMLElement>(codeBlockScopeSelector)
      .forEach((scope) => {
        const copyLabel = scope.dataset.copyLabel ?? "";
        const copiedLabel = scope.dataset.copiedLabel ?? "";

        scope
          .querySelectorAll<HTMLPreElement>("pre[data-language]")
          .forEach((codeBlock) => {
            if (codeBlock.parentElement?.classList.contains("code-block")) {
              return;
            }

            const code = codeBlock.querySelector("code");
            if (!code) {
              return;
            }

            const wrapper = document.createElement("div");
            wrapper.className = "code-block";

            const toolbar = document.createElement("div");
            toolbar.className = "code-block-toolbar";

            const languageLabel = document.createElement("span");
            languageLabel.className = "code-language-label";
            languageLabel.textContent = getCodeLanguageLabel(
              codeBlock.dataset.language,
            );

            const button = document.createElement("button");
            button.type = "button";
            button.className = "code-copy-button";
            button.setAttribute("aria-label", copyLabel);
            button.setAttribute("aria-live", "polite");

            const copyText = document.createElement("span");
            copyText.className = "copy-label";
            copyText.textContent = copyLabel;
            copyText.setAttribute("aria-hidden", "true");

            const copiedText = document.createElement("span");
            copiedText.className = "copied-label";
            copiedText.textContent = copiedLabel;
            copiedText.setAttribute("aria-hidden", "true");

            button.append(copyText, copiedText);

            let resetTimer: number | undefined;

            button.addEventListener("click", async () => {
              try {
                await navigator.clipboard.writeText(code.textContent ?? "");
                button.setAttribute("aria-label", copiedLabel);
                button.dataset.state = "copied";

                window.clearTimeout(resetTimer);
                resetTimer = window.setTimeout(() => {
                  button.setAttribute("aria-label", copyLabel);
                  delete button.dataset.state;
                }, 1800);
              } catch {
                button.setAttribute("aria-label", copyLabel);
                delete button.dataset.state;
              }
            });

            codeBlock.before(wrapper);
            toolbar.append(languageLabel, button);
            wrapper.append(toolbar, codeBlock);
          });
      });
  }

  document.addEventListener("astro:page-load", enhanceCodeBlocks);
  enhanceCodeBlocks();
</script>

