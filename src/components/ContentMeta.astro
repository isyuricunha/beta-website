---
import Tag from "@/components/Tag.astro";
import type { Locale } from "@/i18n/config";
import { localeMetadata } from "@/i18n/config";
import type { Dictionary } from "@/i18n/types";

type Props = {
  publishedDate?: Date | undefined;
  updatedDate?: Date | undefined;
  readingMinutes?: number | undefined;
  tags?: string[] | undefined;
  locale: Locale;
  dictionary: Dictionary;
};

const {
  publishedDate,
  updatedDate,
  readingMinutes,
  tags = [],
  locale,
  dictionary,
} = Astro.props;
const dateFormatter = new Intl.DateTimeFormat(
  localeMetadata[locale].languageTag,
  { dateStyle: "medium", timeZone: "UTC" },
);
---

<div class="content-meta">
  <div class="facts">
    {
      publishedDate && (
        <span>
          {dictionary.common.published}{" "}
          <time datetime={publishedDate.toISOString()}>
            {dateFormatter.format(publishedDate)}
          </time>
        </span>
      )
    }
    {
      updatedDate && (
        <span>
          {dictionary.common.updated}{" "}
          <time datetime={updatedDate.toISOString()}>
            {dateFormatter.format(updatedDate)}
          </time>
        </span>
      )
    }
    {
      readingMinutes && (
        <span>{dictionary.common.minuteRead(readingMinutes)}</span>
      )
    }
  </div>
  {tags.length > 0 && <div class="tags">{tags.map((tag) => <Tag label={tag} />)}</div>}
</div>

<style>
  .content-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .facts,
  .tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.9rem;
  }

  .facts span {
    color: rgb(161 161 170 / 68%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.015em;
  }

  .facts span + span {
    position: relative;
    padding-left: 1rem;
  }

  .facts span + span::before {
    position: absolute;
    top: 50%;
    left: 0;
    width: 0.18rem;
    height: 0.18rem;
    transform: translateY(-50%);
    border-radius: 50%;
    background: rgb(138 79 22 / 72%);
    content: "";
  }
</style>
