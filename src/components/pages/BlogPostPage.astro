---
import { render, type CollectionEntry } from "astro:content";

import ContentMeta from "@/components/ContentMeta.astro";
import PostList from "@/components/PostList.astro";
import Prose from "@/components/Prose.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { getDictionary } from "@/i18n";
import type { Locale } from "@/i18n/config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSectionPath } from "@/lib/routes";
import { estimateReadingMinutes, parseContentId } from "@/lib/content-utils";
import { getAdjacentPosts, getRelatedPosts, getContentPath } from "@/lib/content";

type Props = {
  entry: CollectionEntry<"blog">;
  availableLocales: Locale[];
};

const { entry, availableLocales } = Astro.props;
const { locale, slug } = parseContentId(entry.id);
const dictionary = getDictionary(locale);
const { Content, headings } = await render(entry);
const readingMinutes = estimateReadingMinutes(entry.body ?? "", locale);

const [relatedPosts, adjacentPosts] = await Promise.all([
  getRelatedPosts(locale, slug, entry.data.tags),
  getAdjacentPosts(locale, slug),
]);
const { prev, next } = adjacentPosts;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  locale={locale}
  availableLocales={availableLocales}
  type="article"
  publishedTime={entry.data.publishedDate}
  updatedTime={entry.data.updatedDate}
  tags={entry.data.tags}
>
  <article class="content-page">
    <a class="back-link" href={getSectionPath(locale, "blog")}>
      <span aria-hidden="true">←</span>
      {dictionary.common.backToBlog}
    </a>
    <header>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
      <ContentMeta
        publishedDate={entry.data.publishedDate}
        updatedDate={entry.data.updatedDate}
        readingMinutes={readingMinutes}
        tags={entry.data.tags}
        locale={locale}
        dictionary={dictionary}
      />
    </header>
    <div class:list={["content-grid", { "with-toc": entry.data.showTableOfContents }]}>
      <Prose>
        <Content />
      </Prose>
      {
        entry.data.showTableOfContents && (
          <TableOfContents headings={headings} dictionary={dictionary} />
        )
      }
    </div>
    <footer class="post-footer">
      {relatedPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-posts-title">
          <h2 id="related-posts-title">{dictionary.common.relatedPosts}</h2>
          <PostList
            items={relatedPosts}
            locale={locale}
            dictionary={dictionary}
            compact
          />
        </section>
      )}
      {(prev || next) && (
        <nav class="post-nav" aria-label={dictionary.common.relatedPosts}>
          {prev && (
            <a class="post-nav-link post-nav-prev" href={getContentPath("blog", prev.slug, prev.entryLocale)}>
              <span class="post-nav-label">{dictionary.common.previousPost}</span>
              <span class="post-nav-title">{prev.entry.data.title}</span>
            </a>
          )}
          {next && (
            <a class="post-nav-link post-nav-next" href={getContentPath("blog", next.slug, next.entryLocale)}>
              <span class="post-nav-label">{dictionary.common.nextPost}</span>
              <span class="post-nav-title">{next.entry.data.title}</span>
            </a>
          )}
        </nav>
      )}
      <a class="back-link" href={getSectionPath(locale, "blog")}>
        <span aria-hidden="true">←</span>
        {dictionary.common.backToBlog}
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .content-page {
    padding: clamp(2.85rem, 5vw, 3.6rem) 0 5.25rem;
  }

  .back-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgb(161 161 170 / 82%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.72rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .back-link span {
    color: rgb(199 119 31 / 86%);
    transition: transform 160ms ease;
  }

  .back-link:hover {
    color: var(--color-text);
    transform: translateX(-0.08rem);
  }

  .back-link:hover span {
    transform: translateX(-0.12rem);
  }

  header {
    max-width: 51rem;
    margin: clamp(2.35rem, 5vw, 3rem) 0 clamp(3rem, 5.5vw, 3.7rem);
  }

  h1 {
    margin: 0;
    font-size: clamp(2.45rem, 5.2vw, 4.25rem);
    font-weight: 650;
    letter-spacing: -0.052em;
    line-height: 1.04;
    text-wrap: balance;
  }

  header > p {
    max-width: 46rem;
    margin: 1.25rem 0 1.75rem;
    color: rgb(212 212 216 / 78%);
    font-size: clamp(0.98rem, 1.1vw, 1.05rem);
    line-height: 1.78;
  }

  .content-grid {
    max-width: 43.5rem;
  }

  .content-grid.with-toc {
    display: grid;
    max-width: none;
    grid-template-columns: minmax(0, 43.5rem) minmax(10rem, 13.5rem);
    align-items: start;
    gap: clamp(2.75rem, 6vw, 4.75rem);
  }

  header :global(.content-meta) {
    max-width: 46rem;
    justify-content: flex-start;
    gap: 0.85rem 1.2rem;
  }

  header :global(.content-meta .facts),
  header :global(.content-meta .tags) {
    gap: 0.45rem 0.75rem;
  }

  .content-page :global(.prose) {
    color: rgb(212 212 216 / 86%);
    line-height: 1.88;
  }

  .content-page :global(.prose p) {
    margin-bottom: 1.45rem;
  }

  .content-page :global(.prose h2) {
    margin: 3.1rem 0 0.95rem;
    font-size: clamp(1.55rem, 3vw, 1.82rem);
    letter-spacing: -0.032em;
  }

  .content-page :global(.prose h3) {
    margin: 2.35rem 0 0.75rem;
    font-size: 1.24rem;
    letter-spacing: -0.028em;
  }

  .content-page :global(.prose a) {
    color: var(--color-text);
    text-decoration-color: rgb(199 119 31 / 58%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.24em;
  }

  .content-page :global(.prose a:hover) {
    color: var(--color-accent-bright);
    text-decoration-color: var(--color-accent-bright);
  }

  .content-page :global(.prose ul),
  .content-page :global(.prose ol) {
    margin: 1.35rem 0 1.65rem;
    padding-left: 1.15rem;
  }

  .content-page :global(.prose li) {
    margin: 0.55rem 0;
    padding-left: 0.35rem;
  }

  .content-page :global(.prose li::marker) {
    color: rgb(199 119 31 / 84%);
  }

  .post-footer {
    max-width: 43.5rem;
    margin-top: clamp(3.5rem, 7vw, 4.75rem);
    padding-top: 1.35rem;
    border-top: 1px solid rgb(255 255 255 / 6%);
  }

  .related-posts {
    margin-bottom: 2.5rem;
  }

  .related-posts h2 {
    margin: 0 0 1.5rem;
    font-size: 1.1rem;
    font-weight: 560;
    letter-spacing: -0.02em;
    color: rgb(212 212 216 / 88%);
  }

  .related-posts :global(.post-list) {
    border-top: none;
  }

  .related-posts :global(.post-list article) {
    padding-block: 1.25rem;
  }

  .related-posts :global(.post-list article:first-child) {
    padding-top: 0;
  }

  .related-posts :global(.post-list article:last-child) {
    border-bottom: none;
    padding-bottom: 0;
  }

  .post-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(255 255 255 / 6%);
  }

  .post-nav-link {
    flex: 1;
    min-width: 14rem;
    max-width: 20rem;
    display: block;
    padding: 1rem;
    border: 1px solid rgb(255 255 255 / 7%);
    border-radius: var(--radius-lg);
    background: rgb(255 255 255 / 1.5%);
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .post-nav-link:hover {
    border-color: rgb(199 119 31 / 32%);
    background: rgb(199 119 31 / 4%);
    color: var(--color-accent-bright);
  }

  .post-nav-label {
    display: block;
    margin-bottom: 0.35rem;
    color: rgb(199 119 31 / 78%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .post-nav-title {
    color: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.45;
  }

  .post-nav-prev .post-nav-title {
    text-align: left;
  }

  .post-nav-next .post-nav-title {
    text-align: right;
  }

  @media (max-width: 620px) {
    .post-nav {
      flex-direction: column;
    }

    .post-nav-link {
      max-width: none;
    }

    .post-nav-next .post-nav-title {
      text-align: left;
    }
  }

  @media (max-width: 820px) {
    .content-grid.with-toc {
      grid-template-columns: 1fr;
    }

    .content-grid :global(aside) {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .content-page {
      padding-top: 2.4rem;
    }

    header {
      margin-top: 2rem;
      margin-bottom: 2.75rem;
    }

    header > p {
      margin-top: 1.05rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-link:hover,
    .back-link:hover span {
      transform: none;
    }
  }
</style>
