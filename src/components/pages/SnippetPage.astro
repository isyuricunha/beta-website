---
import { render, type CollectionEntry } from "astro:content";

import CodeBlockTools from "@/components/CodeBlockTools.astro";
import ContentMeta from "@/components/ContentMeta.astro";
import Prose from "@/components/Prose.astro";
import Tag from "@/components/Tag.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { getDictionary } from "@/i18n";
import type { Locale } from "@/i18n/config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSectionPath } from "@/lib/routes";
import { estimateReadingMinutes, parseContentId } from "@/lib/content-utils";

type Props = {
  entry: CollectionEntry<"snippets">;
  availableLocales: Locale[];
};

const { entry, availableLocales } = Astro.props;
const { locale } = parseContentId(entry.id);
const dictionary = getDictionary(locale);
const { Content, headings } = await render(entry);
const readingMinutes = estimateReadingMinutes(entry.body ?? "", locale);
const normalizeTaxonomy = (value: string) => value.trim().toLocaleLowerCase();
const primaryTaxonomy = new Set([
  normalizeTaxonomy(entry.data.category),
  ...entry.data.stack.map(normalizeTaxonomy),
]);
const secondaryTags = entry.data.tags.filter(
  (tag) => !primaryTaxonomy.has(normalizeTaxonomy(tag)),
);
const showTableOfContents =
  headings.filter((heading) => heading.depth === 2).length >= 3;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  locale={locale}
  availableLocales={availableLocales}
  type="article"
  publishedTime={entry.data.publishedDate}
  updatedTime={entry.data.updatedDate}
  tags={entry.data.tags}
>
  <article class="content-page">
    <a class="back-link" href={getSectionPath(locale, "snippets")}>
      <span aria-hidden="true">←</span>
      {dictionary.common.backToSnippets}
    </a>
    <header>
      <div class="classification">
        <span class="category">{entry.data.category}</span>
        <div class="stack">
          {entry.data.stack.map((tool) => <Tag label={tool} />)}
        </div>
      </div>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
      <ContentMeta
        publishedDate={entry.data.publishedDate}
        updatedDate={entry.data.updatedDate}
        readingMinutes={readingMinutes}
        tags={secondaryTags}
        locale={locale}
        dictionary={dictionary}
      />
    </header>
    <div class:list={["content-grid", { "with-toc": showTableOfContents }]}>
      <div
        class="snippet-prose"
        data-code-block-scope
        data-copy-label={dictionary.common.copyCode}
        data-copied-label={dictionary.common.copied}
      >
        <Prose>
          <Content />
        </Prose>
      </div>
      {
        showTableOfContents && (
          <TableOfContents
            headings={headings}
            dictionary={dictionary}
            label={dictionary.common.onThisNote}
          />
        )
      }
    </div>
    <CodeBlockTools />
    <footer class="snippet-footer">
      <a class="back-link" href={getSectionPath(locale, "snippets")}>
        <span aria-hidden="true">←</span>
        {dictionary.common.backToSnippets}
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .content-page {
    padding: clamp(2.85rem, 5vw, 3.6rem) 0 5.25rem;
  }

  .back-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgb(161 161 170 / 82%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.72rem;
    letter-spacing: 0.01em;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.25em;
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease,
      transform 160ms ease;
  }

  .back-link span {
    color: rgb(199 119 31 / 86%);
    transition: transform 160ms ease;
  }

  .back-link:hover {
    color: var(--color-text);
    text-decoration-color: rgb(199 119 31 / 62%);
    transform: translateX(-0.08rem);
  }

  .back-link:hover span {
    transform: translateX(-0.12rem);
  }

  header {
    max-width: 51rem;
    margin: clamp(2.35rem, 5vw, 3rem) 0 clamp(3rem, 5.5vw, 3.7rem);
  }

  .classification {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.35rem;
  }

  .category {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgb(199 119 31 / 78%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.63rem;
    letter-spacing: 0.045em;
    text-transform: lowercase;
  }

  .category::before {
    width: 0.24rem;
    height: 0.24rem;
    border-radius: 50%;
    background: rgb(199 119 31 / 78%);
    box-shadow: 0 0 0.55rem rgb(199 119 31 / 14%);
    content: "";
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.45rem, 5.2vw, 4.25rem);
    font-weight: 650;
    letter-spacing: -0.052em;
    line-height: 1.04;
    text-wrap: balance;
  }

  header > p {
    max-width: 46rem;
    margin: 1.25rem 0 1.75rem;
    color: rgb(212 212 216 / 78%);
    font-size: clamp(0.98rem, 1.1vw, 1.05rem);
    line-height: 1.78;
  }

  header :global(.content-meta) {
    max-width: 46rem;
    justify-content: flex-start;
    gap: 0.85rem 1.2rem;
  }

  header :global(.content-meta .facts),
  header :global(.content-meta .tags) {
    gap: 0.45rem 0.75rem;
  }

  .content-grid {
    max-width: 43.5rem;
  }

  .content-grid.with-toc {
    display: grid;
    max-width: none;
    grid-template-columns: minmax(0, 43.5rem) minmax(10rem, 13.5rem);
    align-items: start;
    gap: clamp(2.75rem, 6vw, 4.75rem);
  }

  .snippet-prose {
    min-width: 0;
  }

  .content-page :global(.prose) {
    color: rgb(212 212 216 / 86%);
    line-height: 1.88;
  }

  .content-page :global(.prose p) {
    margin-bottom: 1.45rem;
  }

  .content-page :global(.prose h2) {
    margin: 3rem 0 0.95rem;
    font-size: clamp(1.5rem, 3vw, 1.75rem);
    letter-spacing: -0.032em;
  }

  .content-page :global(.prose h3) {
    margin: 2.3rem 0 0.75rem;
    font-size: 1.22rem;
    letter-spacing: -0.028em;
  }

  .content-page :global(.prose a) {
    color: var(--color-text);
    text-decoration-color: rgb(199 119 31 / 58%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.24em;
  }

  .content-page :global(.prose a:hover) {
    color: var(--color-accent-bright);
    text-decoration-color: var(--color-accent-bright);
  }

  .content-page :global(.prose ul),
  .content-page :global(.prose ol) {
    margin: 1.35rem 0 1.65rem;
    padding-left: 1.15rem;
  }

  .content-page :global(.prose li) {
    margin: 0.55rem 0;
    padding-left: 0.35rem;
  }

  .content-page :global(.prose li::marker) {
    color: rgb(199 119 31 / 84%);
  }

  .content-page :global(.prose code:not(pre code)) {
    padding: 0.14rem 0.34rem;
    border-color: rgb(199 119 31 / 18%);
    background: rgb(199 119 31 / 5%);
    color: rgb(224 161 58 / 94%);
    font-size: 0.83em;
    line-height: inherit;
  }

  .snippet-footer {
    max-width: 43.5rem;
    margin-top: clamp(3.5rem, 7vw, 4.75rem);
    padding-top: 1.35rem;
    border-top: 1px solid rgb(255 255 255 / 6%);
  }

  @media (max-width: 820px) {
    .content-grid.with-toc {
      grid-template-columns: 1fr;
    }

    .content-grid :global(aside) {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .content-page {
      padding-top: 2.4rem;
    }

    header {
      margin-top: 2rem;
      margin-bottom: 2.75rem;
    }

    header > p {
      margin-top: 1.05rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-link:hover,
    .back-link:hover span {
      transform: none;
    }
  }
</style>
