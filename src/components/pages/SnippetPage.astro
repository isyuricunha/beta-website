---
import { render, type CollectionEntry } from "astro:content";

import ContentMeta from "@/components/ContentMeta.astro";
import Prose from "@/components/Prose.astro";
import Tag from "@/components/Tag.astro";
import { getDictionary } from "@/i18n";
import type { Locale } from "@/i18n/config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSectionPath } from "@/lib/routes";
import { estimateReadingMinutes, parseContentId } from "@/lib/content-utils";

type Props = {
  entry: CollectionEntry<"snippets">;
  availableLocales: Locale[];
};

const { entry, availableLocales } = Astro.props;
const { locale } = parseContentId(entry.id);
const dictionary = getDictionary(locale);
const { Content } = await render(entry);
const readingMinutes = estimateReadingMinutes(entry.body ?? "", locale);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  locale={locale}
  availableLocales={availableLocales}
  type="article"
  publishedTime={entry.data.publishedDate}
  updatedTime={entry.data.updatedDate}
  tags={entry.data.tags}
>
  <article class="content-page">
    <a class="back-link" href={getSectionPath(locale, "snippets")}>
      <span aria-hidden="true">←</span>
      {dictionary.common.backToSnippets}
    </a>
    <header>
      <div class="classification">
        <span>{entry.data.category}</span>
        {entry.data.stack.map((tool) => <Tag label={tool} />)}
      </div>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
      <ContentMeta
        publishedDate={entry.data.publishedDate}
        updatedDate={entry.data.updatedDate}
        readingMinutes={readingMinutes}
        tags={entry.data.tags}
        locale={locale}
        dictionary={dictionary}
      />
    </header>
    <Prose>
      <Content />
    </Prose>
  </article>
</BaseLayout>

<style>
  .content-page {
    max-width: 48rem;
    padding: 4rem 0 7rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-text-faint);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.68rem;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-accent-bright);
  }

  header {
    margin: 4rem 0 5rem;
  }

  .classification {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.5rem;
  }

  .classification > span {
    margin-right: 0.4rem;
    color: var(--color-accent);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.6rem, 7vw, 5rem);
    font-weight: 550;
    letter-spacing: -0.06em;
    line-height: 1;
    text-wrap: balance;
  }

  header > p {
    max-width: 40rem;
    margin: 1.5rem 0 2rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }
</style>
