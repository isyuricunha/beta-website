---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ExternalLink from "@/components/ExternalLink.astro";
import PostList from "@/components/PostList.astro";
import ProjectList from "@/components/ProjectList.astro";
import SnippetList from "@/components/SnippetList.astro";
import { getDictionary } from "@/i18n";
import type { Locale } from "@/i18n/config";
import type { Section } from "@/i18n/types";
import { getLocalizedListing } from "@/lib/content";

type Props = {
  locale: Locale;
  section: Section;
};

const { locale, section } = Astro.props;
const dictionary = getDictionary(locale);
const page = dictionary.pages[section];
const isBlog = section === "blog";
const isSnippets = section === "snippets";
const isProjects = section === "projects";
const isAbout = section === "about";
const isContact = section === "contact";
const archivePage =
  section === "blog" || section === "snippets" || section === "projects"
    ? dictionary.pages[section]
    : undefined;
const blogItems =
  section === "blog" ? await getLocalizedListing("blog", locale) : [];
const snippetItems =
  section === "snippets" ? await getLocalizedListing("snippets", locale) : [];
const projectItems =
  section === "projects" ? await getLocalizedListing("projects", locale) : [];
const archiveCount = isBlog
  ? dictionary.pages.blog.entryCount(blogItems.length)
  : isSnippets
    ? dictionary.pages.snippets.entryCount(snippetItems.length)
    : isProjects
      ? dictionary.pages.projects.entryCount(projectItems.length)
      : undefined;
---

<BaseLayout title={page.title} description={page.description} locale={locale}>
  <article
    class:list={[
      "page",
      {
        "blog-page": isBlog,
        "snippets-page": isSnippets,
        "projects-page": isProjects,
      },
    ]}
  >
    <header
      class:list={[
        "page-header",
        {
          "blog-header": isBlog,
          "snippets-header": isSnippets,
          "projects-header": isProjects,
        },
      ]}
    >
      <p class="page-index">/ {section}</p>
      <h1>{page.title}</h1>
      <p class="page-description">{page.description}</p>
      {
        archiveCount && (
          <p class="archive-count">
            <span aria-hidden="true" />
            {archiveCount}
          </p>
        )
      }
    </header>

    {
      isAbout ? (
        <div class="about-grid">
          <div class="body-copy">
            {dictionary.pages.about.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
          <aside>
            <h2>{dictionary.pages.about.careTitle}</h2>
            <ul>
              {dictionary.pages.about.careItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </aside>
        </div>
      ) : isContact ? (
        <div class="contact-grid">
          <a class="contact-row" href="mailto:me@yuricunha.com">
            <span>01</span>
            <strong>{dictionary.pages.contact.emailLabel}</strong>
            <small>me@yuricunha.com</small>
          </a>
          <ExternalLink
            class="contact-row"
            href="https://github.com/isyuricunha"
            label={dictionary.common.externalLink}
          >
            <span>02</span>
            <strong>{dictionary.pages.contact.githubLabel}</strong>
            <small>@isyuricunha</small>
          </ExternalLink>
          <p class="contact-note">{dictionary.pages.contact.note}</p>
        </div>
      ) : section === "blog" ? (
        blogItems.length > 0 ? (
          <div class="archive-list">
            <PostList
              items={blogItems}
              locale={locale}
              dictionary={dictionary}
              wholeRowLink
            />
          </div>
        ) : (
          <div class="empty-state">
            <span aria-hidden="true" />
            <p>{archivePage?.empty}</p>
          </div>
        )
      ) : section === "snippets" ? (
        snippetItems.length > 0 ? (
          <div class="archive-list">
            <SnippetList
              items={snippetItems}
              locale={locale}
              dictionary={dictionary}
              wholeRowLink
            />
          </div>
        ) : (
          <div class="empty-state">
            <span aria-hidden="true" />
            <p>{archivePage?.empty}</p>
          </div>
        )
      ) : projectItems.length > 0 ? (
        <div class="archive-list">
          <ProjectList
            items={projectItems}
            dictionary={dictionary}
          />
        </div>
      ) : (
        <div class="empty-state">
          <span aria-hidden="true" />
          <p>{archivePage?.empty}</p>
        </div>
      )
    }
  </article>
</BaseLayout>

<style>
  .page {
    min-height: 42rem;
    padding: clamp(4.5rem, 9vw, 6.5rem) 0 5.5rem;
  }

  .blog-page {
    min-height: auto;
    padding: clamp(3.75rem, 7vw, 5.4rem) 0 clamp(3.75rem, 6vw, 4.75rem);
  }

  .snippets-page {
    min-height: auto;
    padding: clamp(3.75rem, 7vw, 5.4rem) 0 clamp(3.75rem, 6vw, 4.75rem);
  }

  .projects-page {
    min-height: auto;
    padding: clamp(3.75rem, 7vw, 5.4rem) 0 clamp(3.75rem, 6vw, 4.75rem);
  }

  .page-header {
    display: grid;
    max-width: 48rem;
    grid-template-columns: minmax(7rem, 0.3fr) minmax(0, 1fr);
    align-items: start;
    gap: 1.25rem 2rem;
  }

  .page-index {
    margin: 0.8rem 0 0;
    color: var(--color-accent);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.75rem, 6vw, 4.75rem);
    font-weight: 590;
    letter-spacing: -0.06em;
    line-height: 0.98;
  }

  .page-description {
    grid-column: 2;
    max-width: 39rem;
    margin: 0.5rem 0 0;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.72;
  }

  .blog-header,
  .snippets-header,
  .projects-header {
    display: block;
    max-width: 44rem;
    padding-bottom: 0;
  }

  .blog-header .page-index,
  .blog-header h1,
  .blog-header .page-description,
  .snippets-header .page-index,
  .snippets-header h1,
  .snippets-header .page-description,
  .projects-header .page-index,
  .projects-header h1,
  .projects-header .page-description {
    grid-column: auto;
  }

  .blog-header .page-index,
  .snippets-header .page-index,
  .projects-header .page-index {
    margin: 0 0 0.8rem;
    color: rgb(199 119 31 / 86%);
  }

  .blog-header h1,
  .snippets-header h1,
  .projects-header h1 {
    font-weight: 560;
    letter-spacing: -0.055em;
  }

  .blog-header .page-description,
  .snippets-header .page-description,
  .projects-header .page-description {
    max-width: 40rem;
    margin-top: 0.9rem;
    font-size: 0.98rem;
    line-height: 1.72;
  }

  .archive-count {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 1rem 0 0;
    color: rgb(161 161 170 / 70%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }

  .archive-count span {
    width: 0.28rem;
    height: 0.28rem;
    border-radius: 50%;
    background: rgb(199 119 31 / 82%);
    box-shadow: 0 0 0.65rem rgb(199 119 31 / 14%);
  }

  .empty-state {
    display: flex;
    min-height: 15rem;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 5rem;
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-xl);
    color: var(--color-text-faint);
  }

  .archive-list {
    margin-top: 4.5rem;
  }

  .blog-page .archive-list,
  .snippets-page .archive-list,
  .projects-page .archive-list {
    margin-top: 2.35rem;
  }

  .empty-state span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 1rem var(--color-accent-glow);
  }

  .empty-state p {
    margin: 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(17rem, 0.75fr);
    gap: clamp(3rem, 9vw, 7rem);
    margin-top: 4.5rem;
  }

  .body-copy {
    max-width: 40rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .body-copy p {
    margin: 0 0 1.5rem;
  }

  aside {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface-base);
  }

  aside h2 {
    margin: 0 0 1.4rem;
    color: var(--color-text);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  aside ul {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  aside li {
    position: relative;
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-size: 0.83rem;
    line-height: 1.6;
  }

  aside li::before {
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 50%;
    background: var(--color-accent);
    content: "";
  }

  .contact-grid {
    display: grid;
    max-width: 48rem;
    margin-top: 4.5rem;
    border-top: 1px solid var(--color-border);
  }

  .contact-grid :global(.contact-row) {
    display: grid;
    min-height: 6rem;
    grid-template-columns: 3rem minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    text-decoration: none;
    transition:
      padding 160ms ease,
      color 160ms ease;
  }

  .contact-grid :global(.contact-row:hover) {
    padding-inline: 1rem;
    color: var(--color-accent-bright);
  }

  .contact-row span {
    color: var(--color-text-faint);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.68rem;
  }

  .contact-row strong {
    font-size: 1rem;
    font-weight: 520;
  }

  .contact-row small {
    color: var(--color-text-faint);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.72rem;
  }

  .contact-note {
    margin: 1.5rem 0 0;
    color: var(--color-text-faint);
    font-size: 0.78rem;
  }

  @media (max-width: 720px) {
    .page-header {
      grid-template-columns: 1fr;
    }

    .page-description {
      grid-column: 1;
    }

    .blog-header,
    .snippets-header,
    .projects-header {
      padding-bottom: 0;
    }

    .blog-header .page-index,
    .blog-header h1,
    .blog-header .page-description,
    .snippets-header .page-index,
    .snippets-header h1,
    .snippets-header .page-description,
    .projects-header .page-index,
    .projects-header h1,
    .projects-header .page-description,
    .archive-count {
      grid-column: 1;
    }

    .archive-count {
      margin-top: 0.9rem;
    }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .contact-grid :global(.contact-row) {
      grid-template-columns: 2rem 1fr auto;
    }

    .contact-row small {
      display: none;
    }
  }
</style>
