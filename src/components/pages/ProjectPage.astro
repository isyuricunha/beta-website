---
import { render, type CollectionEntry } from "astro:content";

import ExternalLink from "@/components/ExternalLink.astro";
import Prose from "@/components/Prose.astro";
import Tag from "@/components/Tag.astro";
import { getDictionary } from "@/i18n";
import { localeMetadata, type Locale } from "@/i18n/config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSectionPath } from "@/lib/routes";
import { parseContentId } from "@/lib/content-utils";
import { getProjectLabels } from "@/lib/project-utils";

type Props = {
  entry: CollectionEntry<"projects">;
  availableLocales: Locale[];
};

const { entry, availableLocales } = Astro.props;
const { locale } = parseContentId(entry.id);
const dictionary = getDictionary(locale);
const { Content } = await render(entry);
const projectLabels = getProjectLabels([...entry.data.stack, ...entry.data.tags]);
const projectLinks = [
  entry.data.repositoryUrl && {
    href: entry.data.repositoryUrl,
    label: dictionary.common.github,
  },
  entry.data.homepageUrl && {
    href: entry.data.homepageUrl,
    label: dictionary.common.website,
  },
  entry.data.externalUrl && {
    href: entry.data.externalUrl,
    label: dictionary.common.externalLink,
  },
].filter((link): link is { href: string; label: string } => Boolean(link));
const sourceLink = projectLinks[0];
const yearFormatter = new Intl.DateTimeFormat(
  localeMetadata[locale].languageTag,
  { year: "numeric", timeZone: "UTC" },
);
const startedAt = entry.data.startDate
  ? yearFormatter.format(entry.data.startDate)
  : undefined;
const details = [
  {
    label: dictionary.pages.projects.detail.status,
    value: dictionary.projectStatuses[entry.data.status],
  },
  {
    label: dictionary.pages.projects.detail.type,
    value: entry.data.category,
  },
  projectLabels.length > 0 && {
    label: dictionary.pages.projects.detail.stack,
    value: projectLabels.join(", "),
  },
  sourceLink && {
    label: dictionary.pages.projects.detail.source,
    value: sourceLink.label,
    href: sourceLink.href,
  },
  startedAt && {
    label: dictionary.pages.projects.detail.started,
    value: startedAt,
  },
].filter(
  (detail): detail is { label: string; value: string; href?: string } =>
    Boolean(detail),
);
---

<BaseLayout
  title={entry.data.name}
  description={entry.data.description}
  locale={locale}
  availableLocales={availableLocales}
>
  <article class="content-page">
    <a class="back-link" href={getSectionPath(locale, "projects")}>
      <span aria-hidden="true">←</span>
      {dictionary.common.backToProjects}
    </a>
    <header>
      <div class="project-kicker">
        <span aria-hidden="true"></span>
        {dictionary.projectStatuses[entry.data.status]}
        <i>/</i>
        {entry.data.category}
      </div>
      <h1>{entry.data.name}</h1>
      <p>{entry.data.description}</p>
      {
        projectLabels.length > 0 && (
          <div
            class="project-taxonomy"
            aria-label={dictionary.pages.projects.detail.stack}
          >
            <strong>{dictionary.pages.projects.detail.stack}</strong>
            <div>
              {projectLabels.map((label) => <Tag label={label} />)}
            </div>
          </div>
        )
      }
      {
        projectLinks.length > 0 && (
          <div class="project-links">
            <strong>{dictionary.pages.projects.detail.links}</strong>
            <div>
              {projectLinks.map((link) => (
                <ExternalLink
                  href={link.href}
                  label={dictionary.common.externalLink}
                >
                  {link.label}
                </ExternalLink>
              ))}
            </div>
          </div>
        )
      }
    </header>
    <div class="project-grid">
      <div class="project-body">
        <Prose>
          <Content />
        </Prose>
      </div>
      <aside class="artifact-details" aria-labelledby="artifact-details-title">
        <h2 id="artifact-details-title">{dictionary.pages.projects.detail.title}</h2>
        <dl>
          {
            details.map((detail) => (
              <div>
                <dt>{detail.label}</dt>
                <dd>
                  {detail.href ? (
                    <ExternalLink
                      href={detail.href}
                      label={dictionary.common.externalLink}
                    >
                      {detail.value}
                    </ExternalLink>
                  ) : (
                    detail.value
                  )}
                </dd>
              </div>
            ))
          }
        </dl>
      </aside>
    </div>
    <footer class="project-footer">
      <a class="back-link" href={getSectionPath(locale, "projects")}>
        <span aria-hidden="true">←</span>
        {dictionary.common.backToProjects}
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .content-page {
    padding: clamp(2.85rem, 5vw, 3.6rem) 0 4.75rem;
  }

  .back-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgb(161 161 170 / 82%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.72rem;
    letter-spacing: 0.01em;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.25em;
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease,
      transform 160ms ease;
  }

  .back-link span {
    color: rgb(199 119 31 / 86%);
    transition: transform 160ms ease;
  }

  .back-link:hover {
    color: var(--color-text);
    text-decoration-color: rgb(199 119 31 / 62%);
    transform: translateX(-0.08rem);
  }

  .back-link:hover span {
    transform: translateX(-0.12rem);
  }

  header {
    max-width: 51rem;
    margin: clamp(2.35rem, 5vw, 3rem) 0 clamp(2.6rem, 5vw, 3.25rem);
  }

  .project-kicker {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.35rem;
    color: rgb(161 161 170 / 74%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.66rem;
    letter-spacing: 0.035em;
    text-transform: uppercase;
  }

  .project-kicker span {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0.85rem rgb(199 119 31 / 18%);
  }

  .project-kicker i {
    color: var(--color-border-strong);
    font-style: normal;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.45rem, 5.2vw, 4.25rem);
    font-weight: 650;
    letter-spacing: -0.052em;
    line-height: 1.04;
    text-wrap: balance;
  }

  header > p {
    max-width: 46rem;
    margin: 1.25rem 0 1.75rem;
    color: rgb(212 212 216 / 78%);
    font-size: clamp(0.98rem, 1.1vw, 1.05rem);
    line-height: 1.78;
  }

  .project-taxonomy,
  .project-links {
    display: grid;
    max-width: 46rem;
    grid-template-columns: 4.25rem minmax(0, 1fr);
    gap: 0.75rem;
    align-items: start;
    margin-top: 0.85rem;
  }

  .project-taxonomy strong,
  .project-links strong {
    padding-top: 0.2rem;
    color: rgb(161 161 170 / 60%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.025em;
    text-transform: uppercase;
  }

  .project-taxonomy div,
  .project-links div {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.65rem;
  }

  .project-links :global(a) {
    color: rgb(212 212 216 / 78%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.68rem;
    text-decoration: underline;
    text-decoration-color: rgb(199 119 31 / 34%);
    text-underline-offset: 0.28em;
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease;
  }

  .project-links :global(a:hover) {
    color: var(--color-accent-bright);
    text-decoration-color: var(--color-accent-bright);
  }

  .project-grid {
    display: grid;
    grid-template-columns: minmax(0, 43.5rem) minmax(12rem, 17rem);
    align-items: start;
    gap: clamp(2.25rem, 5vw, 4.25rem);
  }

  .project-body {
    min-width: 0;
  }

  .content-page :global(.prose) {
    color: rgb(212 212 216 / 86%);
    line-height: 1.88;
  }

  .content-page :global(.prose p) {
    margin-bottom: 1.45rem;
  }

  .content-page :global(.prose h2) {
    margin: 3rem 0 0.95rem;
    font-size: clamp(1.5rem, 3vw, 1.75rem);
    letter-spacing: -0.032em;
  }

  .content-page :global(.prose h3) {
    margin: 2.3rem 0 0.75rem;
    font-size: 1.22rem;
    letter-spacing: -0.028em;
  }

  .content-page :global(.prose a) {
    color: var(--color-text);
    text-decoration-color: rgb(199 119 31 / 58%);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.24em;
  }

  .content-page :global(.prose a:hover) {
    color: var(--color-accent-bright);
    text-decoration-color: var(--color-accent-bright);
  }

  .artifact-details {
    position: sticky;
    top: 6rem;
    padding: 1rem 0 0.1rem 1.25rem;
    border-left: 1px solid rgb(255 255 255 / 7%);
  }

  .artifact-details h2 {
    margin: 0 0 1.15rem;
    color: rgb(244 244 245 / 88%);
    font-size: 0.78rem;
    font-weight: 560;
    letter-spacing: -0.01em;
  }

  dl {
    display: grid;
    gap: 0;
    margin: 0;
  }

  dl div {
    padding: 0.85rem 0;
    border-top: 1px solid rgb(255 255 255 / 5.5%);
  }

  dt {
    margin-bottom: 0.32rem;
    color: rgb(161 161 170 / 58%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.035em;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    color: rgb(212 212 216 / 82%);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  dd :global(a) {
    color: rgb(212 212 216 / 82%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.68rem;
    text-decoration: underline;
    text-decoration-color: rgb(199 119 31 / 34%);
    text-underline-offset: 0.28em;
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease;
  }

  dd :global(a:hover) {
    color: var(--color-accent-bright);
    text-decoration-color: var(--color-accent-bright);
  }

  .project-footer {
    max-width: 43.5rem;
    margin-top: clamp(3.25rem, 6vw, 4.35rem);
    padding-top: 1.35rem;
    border-top: 1px solid rgb(255 255 255 / 6%);
  }

  @media (max-width: 820px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .artifact-details {
      position: static;
      padding: 1.1rem 0 0;
      border-top: 1px solid rgb(255 255 255 / 6%);
      border-left: 0;
    }
  }

  @media (max-width: 620px) {
    .content-page {
      padding-top: 2.4rem;
    }

    header {
      margin-top: 2rem;
      margin-bottom: 2.75rem;
    }

    header > p {
      margin-top: 1.05rem;
    }

    .project-taxonomy,
    .project-links {
      grid-template-columns: 1fr;
      gap: 0.45rem;
      margin-top: 0.95rem;
    }

    .project-taxonomy strong,
    .project-links strong {
      padding-top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-link:hover,
    .back-link:hover span {
      transform: none;
    }
  }
</style>
