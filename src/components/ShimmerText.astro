---
type Props = {
  text: string;
  class?: string;
  delay?: "delay-1" | "delay-2" | "delay-3";
  subtle?: boolean;
};

const { text, class: className, delay, subtle = false } = Astro.props;
---

<span class:list={["text-shimmer", delay, { subtle }, className]} data-text={text}>{text}</span>

<style>
  .text-shimmer {
    display: inline;
    color: inherit;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    line-height: inherit;
    text-transform: inherit;
  }

  @supports ((background-clip: text) or (-webkit-background-clip: text)) {
    .text-shimmer {
      position: relative;
    }

    .text-shimmer::after {
      content: attr(data-text);
      position: absolute;
      left: 0;
      top: 0;
      z-index: 1;
      --shimmer-edge: var(--color-accent);
      --shimmer-peak: #efc16c;

      background-image: linear-gradient(
        100deg,
        transparent 0%,
        var(--shimmer-edge) 30%,
        var(--shimmer-peak) 50%,
        var(--shimmer-edge) 70%,
        transparent 100%
      );
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      opacity: 0;
      pointer-events: none;
      animation-name: text-shimmer-pulse;
      animation-duration: 10.5s;
      animation-timing-function: cubic-bezier(0.45, 0, 0.25, 1);
      animation-iteration-count: infinite;
    }

    .text-shimmer.subtle::after {
      --shimmer-edge: var(--color-accent-soft);
      --shimmer-peak: var(--color-accent-bright);
    }

    .text-shimmer.delay-1::after {
      animation-delay: 2.2s;
    }

    .text-shimmer.delay-2::after {
      animation-delay: 4.1s;
    }

    .text-shimmer.delay-3::after {
      animation-delay: 6.4s;
    }

    @keyframes text-shimmer-pulse {
      0%,
      8%,
      42%,
      100% {
        opacity: 0;
      }

      25% {
        opacity: 1;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .text-shimmer {
        background-image: none;
        animation: none;
        -webkit-text-fill-color: currentColor;
      }
    }
  }
</style>
