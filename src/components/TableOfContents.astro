---
import type { Dictionary } from "@/i18n/types";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  headings: Heading[];
  dictionary: Dictionary;
  label?: string;
};

const { headings, dictionary, label = dictionary.common.tableOfContents } =
  Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth === 2);
---

{
  visibleHeadings.length > 0 && (
    <aside>
      <p>{label}</p>
      <ol>
        {visibleHeadings.map((heading) => (
          <li>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </aside>
  )
}

<style>
  aside {
    position: sticky;
    top: 5.25rem;
    padding-left: 1.1rem;
    border-left: 1px solid rgb(255 255 255 / 7%);
  }

  p {
    margin: 0 0 0.95rem;
    color: rgb(212 212 216 / 72%);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  ol {
    display: grid;
    gap: 0.62rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  a {
    display: inline-block;
    color: rgb(161 161 170 / 72%);
    font-size: 0.76rem;
    line-height: 1.5;
    text-decoration: none;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  a:hover {
    color: rgb(235 181 88);
    transform: translateX(0.12rem);
  }

  a:focus-visible {
    color: var(--color-text);
  }

  @media (prefers-reduced-motion: reduce) {
    a:hover {
      transform: none;
    }
  }
</style>
