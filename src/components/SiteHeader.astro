---
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import LogoMark from "@/components/LogoMark.astro";
import type { Locale } from "@/i18n/config";
import type { Dictionary, Section } from "@/i18n/types";
import { sections } from "@/i18n/types";
import { getLocalizedPath, getSectionPath, stripLocalePrefix } from "@/lib/routes";

type Props = {
  locale: Locale;
  pathname: string;
  dictionary: Dictionary;
  availableLocales?: readonly Locale[] | undefined;
};

const { locale, pathname, dictionary, availableLocales } = Astro.props;
const currentPath = stripLocalePrefix(pathname);

function isSectionActive(section: Section): boolean {
  return currentPath.startsWith(`/${section}/`);
}
---

<header class="site-header">
  <a
    class="home-link"
    href={getLocalizedPath("/", locale)}
    aria-label="Yuri Cunha"
  >
    <LogoMark />
  </a>

  <button
    class="menu-toggle"
    aria-expanded="false"
    aria-controls="mobile-menu"
    aria-label={dictionary.common.openMenu}
    data-open-label={dictionary.common.openMenu}
    data-close-label={dictionary.common.closeMenu}
  >
    <span class="hamburger-box">
      <span class="hamburger-inner"></span>
    </span>
  </button>

  <div class="header-menu-content" id="mobile-menu">
    <nav aria-label={dictionary.common.primaryNavigation}>
      {
        sections.map((section) => (
          <a
            href={getSectionPath(locale, section)}
            aria-current={isSectionActive(section) ? "page" : undefined}
          >
            {dictionary.navigation[section]}
          </a>
        ))
      }
    </nav>
    <div class="header-actions">
      <pagefind-searchbox class="search-box" placeholder={dictionary.common.search ?? "Search"} />
      <LanguageSwitcher
        locale={locale}
        pathname={pathname}
        dictionary={dictionary}
        availableLocales={availableLocales}
      />
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const header = document.querySelector('.site-header');
    const toggle = document.querySelector('.menu-toggle');
    if (!header || !toggle) return;

    // Toggle menu visibility
    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      const newExpanded = !isExpanded;
      toggle.setAttribute('aria-expanded', newExpanded.toString());
      header.classList.toggle('menu-open', newExpanded);
      
      const openLabel = toggle.getAttribute('data-open-label') || 'Open menu';
      const closeLabel = toggle.getAttribute('data-close-label') || 'Close menu';
      toggle.setAttribute('aria-label', newExpanded ? closeLabel : openLabel);
    });

    // Close menu when a navigation link is clicked
    const links = header.querySelectorAll('nav a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        header.classList.remove('menu-open');
        toggle.setAttribute('aria-expanded', 'false');
        const openLabel = toggle.getAttribute('data-open-label') || 'Open menu';
        toggle.setAttribute('aria-label', openLabel);
      });
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (header.classList.contains('menu-open') && !header.contains(e.target as Node)) {
        header.classList.remove('menu-open');
        toggle.setAttribute('aria-expanded', 'false');
        const openLabel = toggle.getAttribute('data-open-label') || 'Open menu';
        toggle.setAttribute('aria-label', openLabel);
      }
    });

    // Close menu on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.classList.contains('menu-open')) {
        header.classList.remove('menu-open');
        toggle.setAttribute('aria-expanded', 'false');
        const openLabel = toggle.getAttribute('data-open-label') || 'Open menu';
        toggle.setAttribute('aria-label', openLabel);
        (toggle as HTMLElement).focus();
      }
    });
  }

  // Initialize on load and on page navigation
  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>

<style>
  .site-header {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem;
    border: 1px solid rgb(255 255 255 / 7%);
    border-radius: var(--radius-lg);
    background: rgb(3 3 3 / 78%);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 3%),
      0 0.75rem 2.5rem rgb(0 0 0 / 22%);
    backdrop-filter: blur(12px);
  }

  .home-link {
    display: flex;
    border-radius: 0.8rem;
    text-decoration: none;
  }

  .header-menu-content {
    display: contents;
  }

  nav {
    display: flex;
    min-width: 0;
    align-items: center;
    justify-content: flex-end;
    gap: 0.15rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  nav::-webkit-scrollbar {
    display: none;
  }

  nav a {
    position: relative;
    flex: none;
    padding: 0.65rem 0.75rem;
    border-radius: 0.7rem;
    color: var(--color-text-faint);
    font-size: 0.76rem;
    font-weight: 480;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition:
      color 150ms ease,
      background-color 150ms ease,
      box-shadow 180ms ease;
  }

  nav a::after {
    position: absolute;
    right: 0.75rem;
    bottom: 0.35rem;
    left: 0.75rem;
    height: 1px;
    transform: scaleX(0);
    transform-origin: right;
    background: rgb(224 161 58 / 72%);
    content: "";
    transition:
      transform 180ms ease,
      background-color 180ms ease;
  }

  nav a:hover {
    color: var(--color-text);
  }

  nav a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
    background: rgb(224 161 58 / 52%);
  }

  nav a[aria-current="page"] {
    background: rgb(199 119 31 / 5%);
    color: var(--color-accent-bright);
    box-shadow:
      inset 0 0 0 1px rgb(224 161 58 / 6%),
      0 0 1.1rem rgb(199 119 31 / 4%);
  }

  nav a[aria-current="page"]::after {
    transform: scaleX(1);
    background: var(--color-accent-bright);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .search-box {
    --pagefind-ui-scale: 0.9;
    min-width: 14rem;
  }

  .search-box::part(input) {
    background: var(--color-surface-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-jetbrains-mono), monospace;
    font-size: 0.72rem;
    padding: 0.4rem 0.75rem;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      background-color 150ms ease;
  }

  .search-box::part(input):hover {
    border-color: var(--color-border-strong);
  }

  .search-box::part(input):focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow:
      0 0 0 2px rgb(199 119 31 / 18%),
      0 0 0 1px var(--color-accent);
  }

  .search-box::part(input)::placeholder {
    color: var(--color-text-faint);
  }

  .search-box::part(result) {
    background: rgb(7 7 7 / 96%);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    box-shadow: 0 1.5rem 4rem rgb(0 0 0 / 45%);
  }

  .search-box::part(result-item) {
    background: transparent;
    border-radius: 0.65rem;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    padding: 0.55rem 0.65rem;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .search-box::part(result-item):hover,
  .search-box::part(result-item):focus {
    background: rgb(199 119 31 / 10%);
    color: var(--color-text);
  }

  .search-box::part(result-title) {
    color: var(--color-text);
    font-weight: 500;
  }

  .search-box::part(result-excerpt) {
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }

  .menu-toggle {
    display: none;
    background: transparent;
    border: none;
    padding: 0.6rem;
    cursor: pointer;
    color: var(--color-text-faint);
    border-radius: var(--radius-sm);
    transition: color 150ms ease, background-color 150ms ease;
  }

  .menu-toggle:hover,
  .menu-toggle:focus-visible {
    color: var(--color-text);
    background-color: rgb(255 255 255 / 5%);
  }

  .hamburger-box {
    position: relative;
    display: inline-block;
    width: 1.25rem;
    height: 12px;
  }

  .hamburger-inner,
  .hamburger-inner::before,
  .hamburger-inner::after {
    position: absolute;
    width: 1.25rem;
    height: 2px;
    left: 0;
    background-color: currentColor;
    border-radius: 4px;
    transition: transform 0.2s ease, background-color 0.2s ease, opacity 0.2s ease;
  }

  .hamburger-inner {
    top: 50%;
    transform: translateY(-50%);
    left: 0;
  }

  .hamburger-inner::before {
    top: -5px;
    content: "";
  }

  .hamburger-inner::after {
    bottom: -5px;
    content: "";
  }

  /* Animating to X when open */
  :global(.site-header.menu-open) .hamburger-inner {
    background-color: transparent;
  }

  :global(.site-header.menu-open) .hamburger-inner::before {
    transform: translateY(5px) rotate(45deg);
  }

  :global(.site-header.menu-open) .hamburger-inner::after {
    transform: translateY(-5px) rotate(-45deg);
  }

  @keyframes menu-slide-down {
    from {
      opacity: 0;
      transform: translateY(-0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 740px) {
    .site-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.45rem 0.65rem;
    }

    .menu-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header-menu-content {
      display: none;
    }

    :global(.site-header.menu-open) .header-menu-content {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 0;
      right: 0;
      z-index: 20;
      padding: 1rem;
      border: 1px solid rgb(255 255 255 / 8%);
      border-radius: var(--radius-lg);
      background: rgb(3 3 3 / 94%);
      box-shadow:
        inset 0 1px 0 rgb(255 255 255 / 3%),
        0 1.5rem 4rem rgb(0 0 0 / 55%);
      backdrop-filter: blur(20px);
      gap: 1rem;
      animation: menu-slide-down 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    }

    nav {
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      width: 100%;
      padding: 0;
    }

    nav a {
      width: 100%;
      padding: 0.75rem 0.85rem;
      font-size: 0.84rem;
      border-radius: var(--radius-md);
      background: rgb(255 255 255 / 2.5%);
      border: 1px solid rgb(255 255 255 / 3.5%);
      color: var(--color-text-muted);
      transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;
    }

    nav a:hover,
    nav a:focus {
      background: rgb(255 255 255 / 5%);
      border-color: rgb(255 255 255 / 8%);
      color: var(--color-text);
    }

    nav a[aria-current="page"] {
      background: rgb(199 119 31 / 8%);
      border-color: rgb(224 161 58 / 20%);
      color: var(--color-accent-bright);
      box-shadow: 0 0 1rem rgb(199 119 31 / 3%);
    }

    nav a::after {
      display: none;
    }

    .header-actions {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
      width: 100%;
      border-top: 1px solid rgb(255 255 255 / 8%);
      padding-top: 1rem;
    }

    .search-box {
      width: 100%;
      min-width: 0;
    }

    .search-box::part(input) {
      width: 100%;
      font-size: 0.78rem;
      padding: 0.5rem 0.75rem;
      background: rgb(255 255 255 / 1.5%);
    }

    :global(.language-switcher) {
      width: 100%;
    }

    :global(.language-switcher) summary {
      width: 100%;
      min-height: 2.3rem;
      justify-content: space-between;
      padding: 0.5rem 0.85rem;
      border-color: var(--color-border);
      background: rgb(255 255 255 / 1.5%);
    }

    :global(.language-switcher[open]) summary {
      border-color: var(--color-accent-soft);
      background: var(--color-surface-raised-base);
    }

    :global(.language-switcher) .language-menu {
      position: static;
      width: 100%;
      margin-top: 0.5rem;
      border-color: var(--color-border-strong);
      box-shadow: none;
      background: rgb(5 5 5 / 80%);
    }
  }
</style>
